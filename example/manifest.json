{
  "id": "com.example.finance",
  "name": "Finance Perso",
  "version": "1.0.0",
  "icon": "assets/icon.png",
  "description": "Suivi de budget personnel",
  "entry": "home",
  "pages": {
    "home": {
      "name": "Accueil",
      "icon": "account_balance_wallet",
      "source": "pages/home.ks"
    },
    "add_transaction": {
      "name": "Ajouter",
      "icon": "add",
      "source": "pages/add_transaction.ks"
    },
    "stats": {
      "name": "Statistiques",
      "icon": "bar_chart",
      "source": "pages/stats.ks"
    },
    "stats_detail": {
      "name": "Detail statistiques",
      "icon": "insights",
      "source": "pages/stats_detail.ks"
    },
    "stats_export": {
      "name": "Export statistiques",
      "icon": "download",
      "source": "pages/stats_export.ks"
    }
  },
  "utils": [
    "utils/theme.ks",
    "store/finance_store.ks"
  ],
  "window": {
    "navigationBarTitleText": "Finance Perso",
    "navigationBarBackgroundColor": "#ffffff",
    "navigationBarTextStyle": "black"
  },
  "tabBar": {
    "list": [
      {
        "pagePath": "home",
        "text": "Accueil",
        "iconPath": "assets/icons/home.png"
      },
      {
        "pagePath": "stats",
        "text": "Statistiques",
        "iconPath": "assets/icons/stats.png"
      },
      {
        "pagePath": "add_transaction",
        "text": "Ajouter"
      }
    ]
  },
  "scopes": {
    "scope.userLocation": {
      "desc": "Votre position est utilisee pour geolocaliser vos depenses"
    },
    "scope.camera": {
      "desc": "Scanner vos recus et tickets de caisse"
    }
  },
  "networkTimeout": {
    "request": 10000,
    "uploadFile": 30000,
    "downloadFile": 30000
  },
  "subpackages": [
    {
      "root": "packageStats",
      "pages": [
        "stats_detail",
        "stats_export"
      ]
    }
  ]
}
